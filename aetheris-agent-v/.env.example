# Aetheris\aetheris-agent-v\.env.example

# ── RPC Endpoints ─────────────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
BASE_SEPOLIA_WS_URL=wss://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# Optional: QuickNode failover (leave blank if you don't have one)
QUICKNODE_SEPOLIA_RPC_URL=

# ── Mainnet (fill in when ready to deploy) ────────────────────────
BASE_MAINNET_RPC_URL=
BASE_MAINNET_WS_URL=

# ── Chain ─────────────────────────────────────────────────────────
# 84532 = Base Sepolia  |  8453 = Base Mainnet
CHAIN_ID=84532

# ── Wallet ────────────────────────────────────────────────────────
# Guardian wallet — signs all emergency transactions (pause, emergencyReturn).
# Fund with ~0.05 ETH on Base Sepolia to start.
BUNDLER_PRIVATE_KEY=

# ── Contract Addresses ────────────────────────────────────────────
AGENT_ALPHA_ADDR=
AGENT_BETA_ADDR=
VAULT_ADDR=
MULTICALL3_ADDR=0xcA11bde05977b3631167028862bE2a173976CA11
WATCHED_CONTRACTS=

# ── Agent Settings ────────────────────────────────────────────────
# Chainlink ETH/USD feed address on Base
CHAINLINK_ETH_USD=0x71041dddad3595F9CEd3DcCFBe3D1F4b0a16Bb70

# Pyth contract and ETH/USD feed ID on Base
PYTH_CONTRACT=0x8250f4aF4B972684F7b336503E2D6dFeDeB1487a
PYTH_ETH_USD_FEED_ID=0xff61491a931112ddf1bd8147cd1b641375f79f5825126d665480874634fd0ace

# Alert if Chainlink vs Pyth diverges more than this (in bps — 500 = 5%)
ORACLE_DIVERGENCE_BPS=500

# Consecutive RPC failures before on-chain responses are halted
CIRCUIT_BREAKER_THRESHOLD=5

# ── Database ──────────────────────────────────────────────────────
DB_PATH=./data/agent_v.db

# ── Alerts (optional) ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

