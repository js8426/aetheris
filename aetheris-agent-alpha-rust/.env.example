# Aetheris / aetheris-arb-rs / .env
# Copy to project root and fill in real values.

# ── RPC Endpoints ─────────────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/xSPNRO6ngE0zPdRzEjg5j
BASE_SEPOLIA_WS_URL=wss://base-sepolia.g.alchemy.com/v2/xSPNRO6ngE0zPdRzEjg5j

# ── Wallet ────────────────────────────────────────────────────────
PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# ── Trading Settings ──────────────────────────────────────────────
MIN_PROFIT_USDC=1.0

# ── Alerts (optional) ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# ── Logging ───────────────────────────────────────────────────────
# Examples: aetheris_arb=debug   or   aetheris_arb=trace,warn
RUST_LOG=aetheris_arb=info
