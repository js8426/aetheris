# Aetheris\agent_gas\.env.example

# ── RPC Endpoints ─────────────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
BASE_SEPOLIA_WS_URL=wss://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# Optional: QuickNode failover (leave blank if you don't have one)
QUICKNODE_SEPOLIA_RPC_URL=

# ── Mainnet (fill in when ready to deploy) ────────────────────────
BASE_MAINNET_RPC_URL=
BASE_MAINNET_WS_URL=

# ── Chain ─────────────────────────────────────────────────────────
# 84532 = Base Sepolia  |  8453 = Base Mainnet
CHAIN_ID=84532

# ── Wallet ────────────────────────────────────────────────────────
# Bundler wallet — submits handleOps() to EntryPoint, reimbursed after.
# Fund with ~0.1 ETH on Base Sepolia to start.
BUNDLER_PRIVATE_KEY=

# Paymaster signer — signs paymasterAndData for sponsored UserOps.
# Must be registered in AetherisPaymaster.sol via addSigner().
# Does NOT need ETH balance — signing only.
PAYMASTER_SIGNER_KEY=

# ── Contract Addresses ────────────────────────────────────────────
ENTRY_POINT_ADDR=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789
PAYMASTER_ADDR=
ACCOUNT_FACTORY_ADDR=
VAULT_ADDR=
STAKING_ADDR=

# ── Agent Settings ────────────────────────────────────────────────
# Milliseconds between bundle submission attempts
BUNDLE_INTERVAL_MS=2000

# Maximum UserOperations per bundle
MAX_BUNDLE_SIZE=10

# Max gas to sponsor per UserOp in USDC (6 decimals) — 5000000 = $5.00
MAX_SPONSORED_GAS_USDC=5000000

# Gas overhead buffer added to all estimates (%)
GAS_OVERHEAD_PCT=10

# ── Server ────────────────────────────────────────────────────────
PORT=3000

# ── Database ──────────────────────────────────────────────────────
DB_PATH=./data/agent_gas.db

# ── Alerts (optional) ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
