# Aetheris\aetheris-agent-alpha\.env.priority3.example

# ============================================================
# Aetheris Priority 3 — Environment Variables Template
# ============================================================
# Instructions:
#   1. Copy this file to a new file named exactly:  .env
#   2. Fill in every value below with your real credentials
#   3. NEVER commit .env to git — it contains private keys
# ============================================================

# ── RPC Endpoints ────────────────────────────────────────────
BASE_RPC_PRIMARY=https://mainnet.base.org
BASE_RPC_SECONDARY=https://base.llamarpc.com
BASE_RPC_TERTIARY=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ALCHEMY_KEY=your_alchemy_key_here

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=change_this_in_production

# ── Deployed Contract Addresses ──────────────────────────────
# Fill these in after deploying ProofOfExit.sol to Base Sepolia
PROOF_OF_EXIT_ADDRESS=0x0000000000000000000000000000000000000000

# The private key of the wallet that has EXECUTOR_ROLE
# This wallet calls executeExit() when threat score >= threshold
EXECUTOR_PRIVATE_KEY=0x_your_executor_private_key_never_commit_this

# ── Basescan API (for fetching verified source code) ─────────
BASESCAN_API_KEY=your_basescan_api_key

# ── AI Analysis (Claude API) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key

# ── Email Alerts (SendGrid) ──────────────────────────────────
SENDGRID_API_KEY=SG.your_sendgrid_key
FROM_EMAIL=security@aetheris.io
# Comma-separated list of recipients
ALERT_EMAIL_RECIPIENTS=team@aetheris.io,security@aetheris.io

# ── Discord Alerts ───────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_ALERT_CHANNEL_ID=your_channel_id

# ── Twitter/X Alerts ─────────────────────────────────────────
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret

# ── PagerDuty (on-call escalation for CRITICAL alerts) ───────
PAGERDUTY_INTEGRATION_KEY=your_pagerduty_integration_key

# ── Monitoring Parameters ────────────────────────────────────
# How often to check for new blocks (Base produces a block every ~2 seconds)
POLL_INTERVAL_S=2

# Threat score that triggers autonomous exit (0-100, default 75)
SCORE_THRESHOLD=75

# Set to false to disable autonomous exit (manual guardian exit still works)
AUTONOMOUS_EXIT=true

# ── Webhook URL (Discord or Slack) ───────────────────────────
ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url

# ── Threat Analysis API URL ──────────────────────────────────
# If running locally: http://localhost:8001
# If running via Docker: http://threat-engine-1:8001
THREAT_API_URL=http://localhost:8001

# ── Monitored Contracts ──────────────────────────────────────
# JSON array of contracts for Agent V to watch.
# Fill in the real addresses after testnet deployment.
# is_proxy: true = check EIP-1967 implementation slot for upgrades
MONITORED_CONTRACTS=[{"address":"0x...","name":"AetherisAccountFactory","is_proxy":true,"track_owner":true},{"address":"0x...","name":"AetherisPaymaster","is_proxy":true,"track_owner":true},{"address":"0x...","name":"AetherisStaking","is_proxy":false,"track_owner":true},{"address":"0x...","name":"AetherisToken","is_proxy":false,"track_owner":true}]